<Window x:Class="DesktopClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modern Music Player" Height="750" Width="1000">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Modern Music Player" FontSize="28" FontWeight="Bold" />

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="BtnLocalMusic" Content="Local Music" Width="120" Margin="0,0,10,0" Click="BtnLocalMusic_Click" Background="#007ACC" Foreground="White" />
                <Button x:Name="BtnSpotifyLibrary" Content="Liked Songs" Width="120" Margin="0,0,10,0" Click="BtnSpotifyLibrary_Click" />
                <Button x:Name="BtnAuthSpotify" Content="Connect Spotify" Width="120" Margin="0,0,10,0" Click="BtnAuthSpotify_Click" />
                <TextBlock x:Name="LibraryLabel" FontSize="14" VerticalAlignment="Center" Margin="20,0,0,0" Text="Showing: Local Music" Foreground="#666" />
            </StackPanel>
            
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,0">
                <TextBlock Text="Search Spotify:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold" />
                <TextBox x:Name="SearchBox" Width="300" Padding="5" />
                <Button x:Name="BtnSearch" Content="Search" Width="80" Margin="10,0,0,0" Click="BtnSearch_Click" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock x:Name="CurrentTrackLabel" Text="No track selected" FontSize="12" Foreground="#666" Margin="0,0,0,8" FontStyle="Italic" />
            <ListBox x:Name="SongListBox" MinHeight="200">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" MinWidth="250" />
                            <TextBlock Text=" - " />
                            <TextBlock Text="{Binding Artist}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="BtnPlay" Content="Play" Width="100" Margin="0,0,10,0" Click="BtnPlay_Click" Background="#28a745" Foreground="White" />
                <Button x:Name="BtnPause" Content="Pause" Width="100" Margin="0,0,10,0" Click="BtnPause_Click" />
                <Button x:Name="BtnStop" Content="Stop" Width="100" Margin="0,0,10,0" Click="BtnStop_Click" />
                <Button x:Name="BtnSmartShuffle" Content="Smart Shuffle" Width="140" Click="BtnSmartShuffle_Click" />
            </StackPanel>
            
            <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Volume:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold" />
                <Slider x:Name="VolumeSlider" Width="150" Minimum="0" Maximum="100" Value="100" VerticalAlignment="Center" ValueChanged="VolumeSlider_ValueChanged" />
                <TextBlock x:Name="VolumeLabel" Text="100%" Margin="10,0,0,0" VerticalAlignment="Center" Width="40" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
