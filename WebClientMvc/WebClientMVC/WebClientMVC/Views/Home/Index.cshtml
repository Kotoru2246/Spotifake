@{
    ViewData["Title"] = "Spotifake Player";
}

<header class="auth-bar">
    <div class="auth-brand">
        <div class="brand-mark">S</div>
        <div>
            <div class="sidebar-title">Spotifake</div>
            <div class="sidebar-subtitle">Music Player</div>
        </div>
    </div>
    <div class="auth-actions">
        <div class="auth-user-pill" id="authUserPill">Not signed in</div>
        <button type="button" class="secondary-action" id="loginToggleButton">Log In</button>
        <button type="button" class="secondary-action" id="signupToggleButton">Sign Up</button>
        <button type="button" class="secondary-action auth-logout" id="logoutButton" hidden>Log Out</button>
    </div>
</header>

<div class="login-gate" id="loginGate" hidden>
    <section class="auth-panel" id="authPanel">
        <div class="login-card auth-panel-card">
        <div class="brand-lockup">
            <div class="brand-mark">S</div>
            <div>
                <h2 class="login-title" id="authPanelTitle">Sign in</h2>
                <p class="login-subtitle" id="authPanelSubtitle">Use a demo account to unlock uploads and imports.</p>
            </div>
        </div>

        <div class="credentials-box" id="credentialsBox">
            <h3>Test credentials</h3>
            <div class="credential-row"><span><span class="role-tag">User</span> user_test / user123</span></div>
            <div class="credential-row"><span><span class="role-tag">Artist</span> artist_test / artist123</span></div>
            <div class="credential-row"><span><span class="role-tag">Admin</span> admin_test / admin123</span></div>
        </div>

        <div class="auth-signup-note" id="signupNote" hidden>
            Sign up is not connected to a backend yet. Use one of the demo accounts above to explore the project.
        </div>

        <form id="loginForm">
            <div class="form-group">
                <label for="accountType">Account Type</label>
                <select id="accountType" name="role" required>
                    <option value="user">User</option>
                    <option value="artist">Artist</option>
                    <option value="admin">Admin</option>
                </select>
            </div>
            <div class="form-group">
                <label for="loginUsername">Username</label>
                <input type="text" id="loginUsername" name="username" placeholder="Enter username" required>
            </div>
            <div class="form-group">
                <label for="loginPassword">Password</label>
                <input type="password" id="loginPassword" name="password" placeholder="Enter password" required>
            </div>
            <button type="submit" class="full-width">Login</button>
            <div id="loginError" class="login-error"></div>
            <div id="loginStatus" class="login-status"></div>
        </form>
        </div>
    </section>
</div>

<div class="music-app-shell" id="appShell">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-mark">S</div>
            <div>
                <div class="sidebar-title">Spotifake</div>
                <div class="sidebar-subtitle">Music Player</div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <button class="sidebar-link active" data-section="home" onclick="showSection('home')">Home</button>
            <button class="sidebar-link" data-section="library" onclick="showSection('library')">Library</button>
            <button class="sidebar-link" data-section="imports" onclick="showSection('imports')">Import Songs</button>
            <button class="sidebar-link" data-section="playlists" onclick="showSection('playlists')">Playlists</button>
            <a class="sidebar-link admin-only" id="adminNavLink" href="/admin/dashboard" hidden>Admin Dashboard</a>
        </nav>

        <div class="sidebar-card">
            <div class="sidebar-card-label">Now Playing</div>
            <div class="sidebar-track-title" id="sidebarTrackTitle">Midnight Dreams</div>
            <div class="sidebar-track-artist" id="sidebarTrackArtist">Luna Waves</div>
        </div>
    </aside>

    <main class="main-panel">
        <section class="hero-panel section active" id="home">
            <div class="hero-copy">
                <div class="eyebrow">Featured Playlist</div>
                <h1>Listen, shuffle, loop, and play your music in one dark Spotify-style space.</h1>
                <p>Smart Shuffle is shown as not implemented yet, but the rest of the player works as a polished mock experience.</p>
                <div class="hero-actions">
                    <button onclick="togglePlay()" class="primary-action">Play / Pause</button>
                    <button onclick="toggleShuffle()" class="secondary-action">Shuffle</button>
                    <button onclick="setLoopMode('track')" class="secondary-action">Loop Track</button>
                    <button onclick="setLoopMode('playlist')" class="secondary-action">Loop Playlist</button>
                    <button onclick="smartShuffle()" class="secondary-action muted">Smart Shuffle (Not Implemented Yet)</button>
                </div>
            </div>

            <div class="now-playing-card">
                <div class="album-art" id="albumArt">
                    <div class="album-art-badge">♪</div>
                </div>
                <div class="now-playing-meta">
                    <div class="now-playing-label">Now Playing</div>
                    <div class="now-playing-title" id="currentTrackTitle">Midnight Dreams</div>
                    <div class="now-playing-artist" id="currentTrackArtist">Luna Waves</div>
                    <div class="now-playing-playlist" id="currentPlaylistName">Playlist: Neon Nights</div>
                </div>
            </div>
        </section>

        <section class="library-panel section" id="library">
            <div class="section-header">
                <div>
                    <div class="eyebrow">Library</div>
                    <h2>All Your Songs</h2>
                </div>
                <button onclick="showSection('home')" class="secondary-action">Back to Player</button>
            </div>

            <div class="library-status standalone" id="libraryStatus">Loading songs from C:\Music...</div>

            <div class="search-panel">
                <div class="import-panel-title">Search music by name</div>
                <div class="import-panel-row">
                    <input type="text" id="musicSearchName" placeholder="Enter an artist, song title, or keyword">
                    <button type="button" class="secondary-action" id="musicSearchButton">Show 3-5 Songs</button>
                </div>
                <div class="library-status" id="musicSearchStatus">Type a name and the app will show a small set of matching songs from C:\Music.</div>
                <div class="search-results" id="musicSearchResults"></div>
            </div>

            <div class="import-panel">
                <div class="import-panel-title">Add music to C:\Music</div>
                <div class="import-panel-row">
                    <input type="file" id="backendUpload" accept="audio/*" multiple>
                    <button type="button" class="secondary-action" id="uploadToBackendButton">Upload to Backend Folder</button>
                </div>
                <div class="import-panel-row">
                    <input type="url" id="importUrl" placeholder="Paste a direct audio file URL">
                    <button type="button" class="secondary-action" id="importUrlButton">Import Direct Audio URL</button>
                </div>
                <div class="library-status" id="importStatus">YouTube links are not supported for downloading or conversion. Use a direct audio URL or upload local audio files.</div>
            </div>

            <div class="playlist-grid" id="playlistGrid"></div>
        </section>

        <section class="import-songs-panel section" id="imports">
            <div class="section-header">
                <div>
                    <div class="eyebrow">Import Songs</div>
                    <h2>Add New Music</h2>
                </div>
                <button onclick="showSection('library')" class="secondary-action">View Library</button>
            </div>

            <div class="library-toolbar">
                <div>
                    <div class="library-toolbar-title">Load audio files</div>
                    <div class="library-toolbar-subtitle">Pick local MP3, WAV, OGG, or M4A files to preview them in the player.</div>
                </div>
                <label class="file-button" for="trackLoader">Choose Files</label>
                <input type="file" id="trackLoader" accept="audio/*" multiple hidden>
            </div>

            <div class="import-panel">
                <div class="import-panel-title">Add music to C:\Music</div>
                <div class="import-panel-row">
                    <input type="file" id="backendUpload" accept="audio/*" multiple>
                    <button type="button" class="secondary-action" id="uploadToBackendButton">Upload to Backend Folder</button>
                </div>
                <div class="import-panel-row">
                    <input type="url" id="importUrl" placeholder="Paste a direct audio file URL">
                    <button type="button" class="secondary-action" id="importUrlButton">Import Direct Audio URL</button>
                </div>
                <div class="library-status" id="importStatus">YouTube links are not supported for downloading or conversion. Use a direct audio URL or upload local audio files.</div>
            </div>
        </section>

        <section class="playlists-panel section" id="playlists">
            <div class="section-header">
                <div>
                    <div class="eyebrow">Playlists</div>
                    <h2>Create and Manage Playlists</h2>
                </div>
                <button onclick="showSection('home')" class="secondary-action">Back to Player</button>
            </div>

            <div class="import-panel">
                <div class="import-panel-title">Create playlist</div>
                <div class="import-panel-row">
                    <div class="library-status">Create a playlist with name, image URL, and songs in a popup window.</div>
                    <button type="button" class="primary-action" id="createPlaylistButton">Create Playlist</button>
                </div>
                <div class="library-status" id="playlistStatus">Sign in as a user or artist to create playlists.</div>
            </div>

            <div class="admin-grid admin-grid-music">
                <section class="admin-card">
                    <div class="admin-card-subtitle">Your playlists</div>
                    <div class="admin-list" id="userPlaylistList"></div>
                </section>
                <section class="admin-card">
                    <div class="admin-song-detail-title">Playlist Details</div>
                    <div class="playlist-create-row">
                        <select id="playlistSelect"></select>
                        <select id="playlistSongSelect"></select>
                        <button type="button" class="primary-action" id="addSongToPlaylistButton">Add Song</button>
                    </div>
                    <div class="admin-list" id="playlistSongsList"></div>
                </section>
            </div>
        </section>

        <div class="playlist-modal" id="createPlaylistModal" hidden>
            <div class="playlist-modal-card">
                <h3>Create Playlist</h3>
                <div class="form-group">
                    <label for="createPlaylistName">Playlist Name</label>
                    <input type="text" id="createPlaylistName" placeholder="Enter playlist name">
                </div>
                <div class="form-group">
                    <label for="createPlaylistImageUrl">Image URL</label>
                    <input type="url" id="createPlaylistImageUrl" placeholder="Paste image URL (optional)">
                </div>
                <div class="form-group">
                    <label for="createPlaylistSongs">Songs To Add</label>
                    <select id="createPlaylistSongs" multiple size="8"></select>
                </div>
                <div class="admin-item-actions">
                    <button type="button" class="secondary-action" id="cancelCreatePlaylistButton">Cancel</button>
                    <button type="button" class="primary-action" id="submitCreatePlaylistButton">Create Playlist</button>
                </div>
            </div>
        </div>

        <div class="playlist-modal" id="addSongToPlaylistModal" hidden>
            <div class="playlist-modal-card">
                <h3>Add Song To Playlist</h3>
                <div class="library-status" id="addSongModalTrackLabel"></div>
                <div class="form-group">
                    <label for="addSongPlaylistSelect">Select Playlist</label>
                    <select id="addSongPlaylistSelect"></select>
                </div>
                <div class="admin-item-actions">
                    <button type="button" class="secondary-action" id="cancelAddSongModalButton">Cancel</button>
                    <button type="button" class="primary-action" id="confirmAddSongModalButton">Add To Playlist</button>
                </div>
            </div>
        </div>

        <section class="queue-panel">
            <div class="section-header compact">
                <div>
                    <div class="eyebrow">Queue</div>
                    <h2>Up Next</h2>
                </div>
            </div>
            <div class="queue-list" id="queueList"></div>
        </section>
    </main>
</div>

<footer class="player-bar">
    <div class="player-left">
        <div class="mini-art" id="miniArt"></div>
        <div>
            <div class="player-track" id="playerTrack">Midnight Dreams</div>
            <div class="player-artist" id="playerArtist">Luna Waves</div>
        </div>
    </div>

    <div class="player-center">
        <div class="control-row">
            <button class="icon-button" onclick="previousTrack()">⏮</button>
            <button class="icon-button strong" onclick="togglePlay()" id="playPauseButton">▶</button>
            <button class="icon-button" onclick="nextTrack()">⏭</button>
            <button class="icon-button" id="shuffleButton" onclick="toggleShuffle()">🔀</button>
            <button class="icon-button" id="loopButton" onclick="cycleLoop()">↻</button>
        </div>

        <div class="progress-wrap">
            <span id="currentTime">0:00</span>
            <div class="progress-bar" onclick="seekFromClick(event)">
                <div class="progress-fill" id="progressFill"></div>
            </div>
            <span id="totalTime">3:45</span>
        </div>
    </div>

    <div class="player-right">
        <button class="smart-shuffle-button" onclick="smartShuffle()">Smart Shuffle (Not Implemented Yet)</button>
        <div class="volume-wrap">
            <span>🔊</span>
            <input type="range" id="volumeControl" min="0" max="100" value="72" oninput="setVolume(this.value)">
        </div>
    </div>
</footer>

<audio id="audioPlayer" preload="metadata"></audio>
