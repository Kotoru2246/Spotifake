@{
    ViewData["Title"] = "Spotifake Player";
}

<header class="top-bar">
    <div class="top-bar-left">
        <svg viewBox="0 0 24 24" class="spotify-logo" width="32" height="32" fill="currentColor">
            <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.6.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"></path>
        </svg>
    </div>
    <div class="top-bar-center">
        <button class="nav-btn" onclick="showSection('home')" title="Home">🏠</button>
        <div class="search-bar-container">
            <span class="search-icon">🔍</span>
            <input type="text" id="searchInput" placeholder="What do you want to play?" oninput="handleSearchInput(event)" onkeypress="handleSearchSubmit(event)">
            <button class="browse-btn" onclick="showSection('browse')" title="Browse All">🗂️</button>
            <div id="searchDropdown" class="search-dropdown" hidden></div>
        </div>
    </div>
    <div class="top-bar-right">
        <button class="bell-btn" id="notificationBell" title="What's New">
            🔔<span class="badge" id="bellBadge" hidden></span>
        </button>
        <div class="auth-actions">
            <div class="auth-user-pill" id="authUserPill">Not signed in</div>
            <button type="button" class="secondary-action" id="loginToggleButton">Log In</button>
            <button type="button" class="secondary-action" id="signupToggleButton">Sign Up</button>
            <button type="button" class="secondary-action auth-logout" id="logoutButton" hidden>Log Out</button>
        </div>
    </div>
</header>

<div class="login-gate" id="loginGate" hidden>
    <section class="auth-panel" id="authPanel">
        <div class="login-card auth-panel-card">
            <div class="brand-lockup">
                <div class="brand-mark">S</div>
                <div>
                    <h2 class="login-title" id="authPanelTitle">Sign in to Spotifake</h2>
                    <p class="login-subtitle" id="authPanelSubtitle">Connect with real JWT authentication & SQL Server.</p>
                </div>
            </div>

            <div class="credentials-box" id="credentialsBox">
                <h3>Backend AI Credentials (SQL Server DB)</h3>
                <div class="credential-row" onclick="fillCredentials('user_test', 'User@123', 'user')"><span><span class="role-tag">User</span> user_test / User@123</span></div>
                <div class="credential-row" onclick="fillCredentials('artist_test', 'Artist@123', 'artist')"><span><span class="role-tag">Artist</span> artist_test / Artist@123</span></div>
                <div class="credential-row" onclick="fillCredentials('admin_test', 'Admin@123', 'admin')"><span><span class="role-tag">Admin</span> admin_test / Admin@123</span></div>
            </div>

            <div class="auth-signup-note" id="signupNote" hidden>
                Sign up creates a demo session. Select a demo account above to sign in.
            </div>

            <form id="loginForm">
                <div class="form-group">
                    <label for="accountType">Account Type</label>
                    <select id="accountType" name="role" required>
                        <option value="user">User</option>
                        <option value="artist">Artist</option>
                        <option value="admin">Admin</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="loginUsername">Username</label>
                    <input type="text" id="loginUsername" name="username" placeholder="Enter username" required>
                </div>
                <div class="form-group">
                    <label for="loginPassword">Password</label>
                    <input type="password" id="loginPassword" name="password" placeholder="Enter password" required>
                </div>
                <button type="submit" class="full-width primary-action">Login</button>
                <div id="loginError" class="login-error"></div>
                <div id="loginStatus" class="login-status"></div>
            </form>
        </div>
    </section>
</div>

<div class="music-app-shell" id="appShell">
    <aside class="compact-sidebar">
        <div class="sidebar-top">
            <button class="lib-btn" onclick="showSection('library')" title="Your Library">
                <svg role="img" height="24" width="24" viewBox="0 0 24 24" fill="currentColor"><path d="M3 22a1 1 0 0 1-1-1V3a1 1 0 0 1 2 0v18a1 1 0 0 1-1 1zM15.5 2.134A1 1 0 0 0 14 3v18a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V6.464a1 1 0 0 0-.5-.866l-6-3.464zM9 2a1 1 0 0 0-1 1v18a1 1 0 1 0 2 0V3a1 1 0 0 0-1-1z"></path></svg>
            </button>
            <button class="add-btn" id="quickCreatePlaylistBtn" title="Create playlist or folder" onclick="document.getElementById('createPlaylistModal').style.display = 'flex';">
                <svg role="img" height="16" width="16" viewBox="0 0 16 16" fill="currentColor"><path d="M15.25 8a.75.75 0 0 1-.75.75H8.75v5.75a.75.75 0 0 1-1.5 0V8.75H1.5a.75.75 0 0 1 0-1.5h5.75V1.5a.75.75 0 0 1 1.5 0v5.75h5.75a.75.75 0 0 1 .75.75z"></path></svg>
            </button>
        </div>
        <div class="sidebar-scroll">
            <div class="pinned-item liked-songs-tile" onclick="showSection('playlists')" title="Liked Songs">
                <div class="liked-icon">
                    <svg role="img" height="20" width="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8.667 1.912c-2.193 0-4.049 1.638-4.493 3.738C3.73 7.75 4.382 10.121 7.221 12.879l4.779 4.619 4.779-4.62c2.839-2.757 3.49-5.128 3.047-7.23-.444-2.099-2.3-3.737-4.493-3.737-1.332 0-2.585.602-3.333 1.594A4.32 4.32 0 0 0 8.667 1.912z"></path></svg>
                </div>
            </div>
            <div id="sidebarUserPlaylists"></div>
            <button class="pinned-item admin-only" id="adminNavLink" onclick="window.location.href='/admin/dashboard'" title="Admin Dashboard" hidden>
                <div class="admin-icon">⚙️</div>
            </button>
        </div>
    </aside>

    <main class="main-panel">
        <!-- Home View -->
        <section class="section active" id="home">
            <div class="home-header">
                <div class="category-pills">
                    <button class="pill active">All</button>
                    <button class="pill">Music</button>
                    <button class="pill">Podcasts</button>
                </div>
            </div>
            
            <div class="quick-grid" id="homeQuickGrid">
                <!-- 8 cards populated by JS -->
            </div>

            <div class="section-title-row">
                <h2>Made For You</h2>
                <a href="#" class="show-all-link">Show all</a>
            </div>
            
            <div class="card-carousel" id="homeMadeForYouCarousel">
                <!-- Daily Mixes & Discover Weekly populated by JS -->
            </div>
        </section>

        <!-- Search Results View -->
        <section class="section" id="search-results">
            <div class="search-filters">
                <button class="filter-pill active">All</button>
                <button class="filter-pill">Songs</button>
                <button class="filter-pill">Playlists</button>
                <button class="filter-pill">Albums</button>
                <button class="filter-pill">Artists</button>
            </div>
            <div class="search-content-grid">
                <div class="top-result-col">
                    <h2>Top result</h2>
                    <div class="top-result-card" id="topResultCard">
                    </div>
                </div>
                <div class="songs-result-col">
                    <h2>Songs</h2>
                    <div class="search-songs-list" id="searchSongsList">
                    </div>
                </div>
            </div>
        </section>
        <!-- Browse All View -->
        <section class="section" id="browse">
            <div class="browse-header">
                <h2>Browse all</h2>
            </div>
            <div class="browse-grid" id="browseCategoryGrid">
                <!-- Colorful category cards populated by JS -->
            </div>
        </section>

        <!-- Playlist Detail View -->
        <section class="section" id="playlist-view">
            <div class="playlist-hero">
                <div class="playlist-cover-shadow">
                    <img id="pvCoverArt" src="" alt="Playlist Cover">
                </div>
                <div class="playlist-hero-info">
                    <span class="eyebrow">Playlist</span>
                    <h1 id="pvTitle" class="massive-title">Playlist Title</h1>
                    <div class="playlist-description" id="pvDescription">Description goes here</div>
                    
                    <!-- Waveform and Danmaku Container -->
                    <div class="waveform-container" id="waveformContainer" style="display: none;">
                        <div class="danmaku-layer" id="danmakuLayer"></div>
                        <canvas id="waveformCanvas" width="800" height="80"></canvas>
                        <div class="waveform-progress" id="waveformProgress"></div>
                        <div class="comment-input-popover" id="commentPopover" style="display: none;">
                            <input type="text" id="commentInput" placeholder="Add a comment..." onkeypress="handleCommentSubmit(event)">
                        </div>
                    </div>

                    <div class="playlist-stats">
                        <img id="pvCreatorAvatar" src="" class="creator-avatar" alt="User Avatar" onerror="this.style.display='none'">
                        <span class="creator-name" id="pvCreatorName">Spotifake User</span>
                        <span class="stats-dot">•</span>
                        <span id="pvSongCount">0 songs</span>, 
                        <span class="duration-text" id="pvTotalDuration">about 0 min</span>
                    </div>
                </div>
            </div>
            
            <div class="playlist-action-bar">
                <button class="big-play-btn" id="pvPlayBtn" title="Play">
                    <svg height="28" width="28" viewBox="0 0 24 24" fill="#000"><path d="M7.05 3.606l13.49 7.788a.7.7 0 010 1.212L7.05 20.394A.7.7 0 016 19.788V4.212a.7.7 0 011.05-.606z"></path></svg>
                </button>
                <button class="action-icon-btn" title="Save to Your Library">
                    <svg role="img" height="32" width="32" viewBox="0 0 24 24" fill="currentColor"><path d="M5.21 1.57a6.757 6.757 0 016.708 1.545.124.124 0 00.165 0 6.741 6.741 0 015.715-1.78l.004.001a6.802 6.802 0 015.571 5.376v.003a6.689 6.689 0 01-1.49 5.655l-7.954 9.48a.25.25 0 01-.389 0l-7.954-9.48a6.688 6.688 0 01-1.49-5.655V6.71a6.804 6.804 0 015.57-5.376h.001l.004-.001a6.741 6.741 0 011.535.242z"></path></svg>
                </button>
                <button class="action-icon-btn" title="More options">
                    <svg role="img" height="32" width="32" viewBox="0 0 24 24" fill="currentColor"><path d="M4.5 13.5a1.5 1.5 0 100-3 1.5 1.5 0 000 3zm15 0a1.5 1.5 0 100-3 1.5 1.5 0 000 3zm-7.5 0a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"></path></svg>
                </button>
            </div>
            
            <div class="track-table-container">
                <table class="track-table">
                    <thead>
                        <tr>
                            <th class="col-index">#</th>
                            <th class="col-title">Title</th>
                            <th class="col-album">Album</th>
                            <th class="col-date">Date added</th>
                            <th class="col-duration">🕒</th>
                        </tr>
                    </thead>
                    <tbody id="pvTrackList">
                        <!-- Tracks populated by JS -->
                    </tbody>
                </table>
            </div>
        </section>

        <!-- Fullscreen Lyrics View -->
        <section class="section lyrics-view-section" id="lyrics-view" hidden>
            <div class="lyrics-canvas" id="lyricsCanvas">
                <div class="lyrics-text-container" id="lyricsTextContainer">
                    <div class="lyric-line active">♪ ♪ ♪</div>
                </div>
            </div>
        </section>

        <!-- Library Section -->
        <section class="library-panel section" id="library">
            <div class="section-header">
                <div>
                    <div class="eyebrow">SQL Server Storage</div>
                    <h2>Track Library</h2>
                </div>
                <button onclick="showSection('home')" class="secondary-action">Back to Player</button>
            </div>

            <div class="library-status standalone" id="libraryStatus">Loading songs from SQL Server...</div>

            <div class="playlist-grid" id="playlistGrid"></div>
        </section>

        <!-- AI Song Upload Section -->
        <section class="import-songs-panel section" id="upload-ai">
            <div class="section-header">
                <div>
                    <div class="eyebrow">Real AI Upload & Feature Extraction</div>
                    <h2>Upload Audio File</h2>
                </div>
                <button onclick="showSection('library')" class="secondary-action">View Library</button>
            </div>

            <div class="ai-upload-card">
                <form id="aiUploadForm" class="ai-upload-form">
                    <div class="form-row">
                        <div class="form-group half">
                            <label for="uploadTitle">Song Title *</label>
                            <input type="text" id="uploadTitle" placeholder="e.g. Midnight Dreams" required>
                        </div>
                        <div class="form-group half">
                            <label for="uploadArtist">Artist Name *</label>
                            <input type="text" id="uploadArtist" placeholder="e.g. Luna Waves" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="uploadAlbum">Album Name (Optional)</label>
                        <input type="text" id="uploadAlbum" placeholder="e.g. Neon Nights">
                    </div>

                    <div class="form-group">
                        <label for="uploadAudioFile">Audio File (.mp3, .wav, .flac) *</label>
                        <input type="file" id="uploadAudioFile" accept="audio/*" required>
                    </div>

                    <button type="submit" class="primary-action full-width" id="btnUploadSubmit">
                        🎙️ Upload & Extract AI Features (Save to SQL Server)
                    </button>
                </form>

                <div class="library-status" id="uploadAiStatus">
                    Select an audio file and fill in title/artist. Uploading processes audio with Librosa signal processing and saves metadata directly into SQL Server (`MusicPlayerDb`).
                </div>
            </div>
        </section>

        <!-- Playlists Section -->
        <section class="playlists-panel section" id="playlists">
            <div class="section-header">
                <div>
                    <div class="eyebrow">Playlists</div>
                    <h2>Create & Manage Playlists</h2>
                </div>
                <button onclick="showSection('home')" class="secondary-action">Back to Player</button>
            </div>

            <div class="import-panel">
                <div class="import-panel-title">Create Playlist</div>
                <div class="import-panel-row">
                    <div class="library-status">Organize uploaded songs into playlists.</div>
                    <button type="button" class="primary-action" id="createPlaylistButton">Create Playlist</button>
                </div>
                <div class="library-status" id="playlistStatus">Sign in to manage playlists.</div>
            </div>

            <div class="admin-grid admin-grid-music">
                <section class="admin-card">
                    <div class="admin-card-subtitle">Your Playlists</div>
                    <div class="admin-list" id="userPlaylistList"></div>
                </section>
                <section class="admin-card">
                    <div class="admin-song-detail-title">Playlist Details</div>
                    <div class="playlist-create-row">
                        <select id="playlistSelect"></select>
                        <select id="playlistSongSelect"></select>
                        <button type="button" class="primary-action" id="addSongToPlaylistButton">Add Song</button>
                    </div>
                    <div class="admin-list" id="playlistSongsList"></div>
                </section>
            </div>
        </section>

    </main>

    <!-- 3. Right Side Panel -->
    <aside class="right-side-panel" id="rightSidePanel" hidden>
        <div class="right-panel-header">
            <h3 id="rightPanelContextTitle">My Playlist #1</h3>
            <button class="icon-button" onclick="toggleQueuePanel()" title="Close">×</button>
        </div>
        <div class="right-panel-scroll">
            <div id="rightPanelNowPlayingView">
                <div class="large-album-art" id="rightPanelArtContainer">
                    <div class="large-art-placeholder" id="rightPanelArt">♪</div>
                </div>
                <div class="right-panel-meta">
                    <div class="title-row">
                        <div>
                            <div class="track-title" id="rightPanelTrackTitle">Title</div>
                            <div class="track-artist" id="rightPanelTrackArtist">Artist</div>
                        </div>
                        <button class="add-to-playlist-btn" onclick="openAddToPlaylistModal()" title="Add to playlist">+</button>
                    </div>
                </div>

                <div class="artist-credits-card">
                    <div class="credits-header">
                        <h4>Credits</h4>
                        <button class="text-link">Show all</button>
                    </div>
                    <div class="credits-body">
                        <div class="credit-artist-info">
                            <div class="credit-artist-name" id="rightPanelCreditName">Artist</div>
                            <div class="credit-role">Main Artist</div>
                        </div>
                        <button class="follow-btn" id="rightPanelFollowBtn" onclick="toggleFollowArtist()">Follow</button>
                    </div>
                </div>
            </div>

            <div id="rightPanelQueueView" hidden>
                <div class="queue-section-title">Now playing</div>
                <div id="queueNowPlayingCard"></div>
                <div class="queue-section-title" id="queueNextFromContext">Next up</div>
                <div class="queue-list" id="queueList"></div>
            </div>
        </div>
    </aside>
</div>

<footer class="player-bar">
    <div class="player-left">
        <div class="mini-art" id="miniArt">♪</div>
        <div class="player-track-info">
            <div class="player-track" id="playerTrack">No Track Selected</div>
            <div class="player-artist" id="playerArtist">Upload audio to begin</div>
        </div>
        <button class="add-to-playlist-btn" onclick="openAddToPlaylistModal()" title="Save to Your Library">+</button>
    </div>

    <div class="player-center">
        <div class="control-row">
            <button class="icon-button" id="shuffleButton" onclick="toggleShuffle()" title="Enable shuffle">🔀</button>
            <button class="icon-button" onclick="previousTrack()" title="Previous">⏮</button>
            <button class="icon-button strong" onclick="togglePlay()" id="playPauseButton" title="Play">▶</button>
            <button class="icon-button" onclick="nextTrack()" title="Next">⏭</button>
            <button class="icon-button" id="loopButton" onclick="cycleLoop()" title="Enable repeat">↻</button>
        </div>

        <div class="progress-wrap">
            <span id="currentTime" class="time-label">0:00</span>
            <div class="progress-bar" onclick="seekFromClick(event)">
                <div class="progress-fill" id="progressFill">
                    <div class="progress-thumb"></div>
                </div>
            </div>
            <span id="totalTime" class="time-label">0:00</span>
        </div>
    </div>

    <div class="player-right">
        <button class="right-icon-btn" onclick="toggleLyricsView()" title="Lyrics">🎤</button>
        <button class="right-icon-btn" onclick="toggleQueuePanel()" title="Queue">≡</button>
        <button class="right-icon-btn" onclick="toggleMiniPlayer()" title="Mini Player">🗔</button>
        <div class="volume-wrap">
            <button class="right-icon-btn" onclick="toggleMute()" title="Mute">🔊</button>
            <div class="volume-slider-bar">
                <input type="range" id="volumeControl" min="0" max="100" value="72" oninput="setVolume(this.value)">
            </div>
        </div>
    </div>
</footer>

<audio id="audioPlayer" preload="metadata"></audio>

